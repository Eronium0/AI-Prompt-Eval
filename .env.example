# Copy this file to .env.local and fill in your key.
# Get a key at https://console.anthropic.com/
# .env.local is gitignored — never commit your real key.
ANTHROPIC_API_KEY=sk-ant-...

# Demo mode: serve simulated (fake) outputs so the app works with NO key and no
# cost. It's automatic when ANTHROPIC_API_KEY is unset. Set this to 1 to force
# demo mode even when a key is present (e.g. a key with no credits).
# PROMPT_EVAL_DEMO=1
